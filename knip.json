{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["turbo.json"]
    },
    "apps/api": {
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "content.config.ts",
        "playwright.config.ts",
        "e2e/**/*.ts",
        "pages/**/*.vue",
        "layouts/**/*.vue",
        "components/**/*.vue",
        "composables/**/*.ts",
        "plugins/**/*.ts",
        "middleware/**/*.ts",
        "stores/**/*.ts",
        "utils/**/*.ts"
      ],
      "project": ["**/*.{ts,vue}"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "tools/*": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@blankcode/shared",
    "tailwindcss",
    "@vitest/coverage-v8",
    "drizzle-orm",
    "vite",
    "@playwright/test"
  ],
  "ignoreWorkspaces": ["content"],
  "ignoreExportsUsedInFile": true
}
