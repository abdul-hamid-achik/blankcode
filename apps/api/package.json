{
  "name": "@blankcode/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "start:worker": "bun src/workers/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@blankcode/db": "workspace:*",
    "@blankcode/shared": "workspace:*",
    "@effect/cluster": "^0.56.4",
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/rpc": "^0.73.1",
    "@effect/sql": "^0.49.0",
    "@effect/workflow": "^0.16.0",
    "bcrypt": "^5.1.1",
    "effect": "^3.19.18",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "^1.3.9",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.41.0"
  }
}
