# Registry and version (set by CI/CD)
REGISTRY=ghcr.io/your-github-username
VERSION=latest

# Application
CORS_ORIGIN=https://blankcode.dev
ADMIN_EMAILS=you@email.com

# Caddy
API_DOMAIN=api.blankcode.dev

# Secrets are managed via Docker Swarm secrets, NOT env vars.
# Create them with:
#   echo "postgresql://...@ep-xxx-pooler.neon.tech/blankcode?sslmode=require" | docker secret create database_url -
#   openssl rand -base64 64 | docker secret create jwt_secret -
